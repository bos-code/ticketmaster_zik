{
  "expo": {
    "name": "ticketmaster_zik",
    "slug": "zik",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Correctapp_icon.png",
    "scheme": "ticketmasterzik",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.johnderadev.ticketmasterzik",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.johnderadev.ticketmasterzik",
      "adaptiveIcon": {
        "backgroundColor": "#050505",
        "foregroundImage": "./assets/Correctapp_icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/Correctapp_icon.png",
      "name": "Ticketmaster Admin",
      "shortName": "Tickets",
      "themeColor": "#F8FAFC",
      "backgroundColor": "#F8FAFC",
      "display": "fullscreen",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#007AFF",
          "image": "./assets/images/app-icon-t.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#007AFF",
            "image": "./assets/images/app-icon-t.png",
            "imageWidth": 180,
            "resizeMode": "contain"
          },
          "ios": {
            "backgroundColor": "#007AFF",
            "image": "./assets/images/app-icon-t.png",
            "imageWidth": 180,
            "resizeMode": "contain"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ticketmaster_zik to access your location so you can preview routes to venues."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ticketmaster_zik to access your photos so admins can upload event artwork."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow ticketmaster_zik to access your contacts to transfer tickets."
        }
      ],
      "expo-notifications",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a504ff1f-1b23-4c4e-8078-d02ee3ec946f"
      }
    },
    "owner": "macaes-organization",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a504ff1f-1b23-4c4e-8078-d02ee3ec946f"
    }
  }
}
