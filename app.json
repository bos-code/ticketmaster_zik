{
  "expo": {
    "name": "ticketmaster_zik",
    "slug": "ticketmasterzik",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ticketmasterzik",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.johnderadev.ticketmasterzik",
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.johnderadev.ticketmasterzik",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "@clerk/expo",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8FAFC",
          "image": "./assets/images/splash-t-mark.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#F8FAFC",
            "image": "./assets/images/splash-t-mark.png",
            "imageWidth": 180,
            "resizeMode": "contain"
          },
          "ios": {
            "backgroundColor": "#F8FAFC",
            "image": "./assets/images/splash-t-mark.png",
            "imageWidth": 180,
            "resizeMode": "contain"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e9f5dfc6-fbab-4402-bf28-057f180c7b3f"
      }
    },
    "owner": "johnderadev",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e9f5dfc6-fbab-4402-bf28-057f180c7b3f"
    }
  }
}
